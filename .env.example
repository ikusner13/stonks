# OpenRouter — https://openrouter.ai/keys  (required)
OPENROUTER_API_KEY=

# Finnhub — https://finnhub.io/  (optional; real-time US quotes + news, 60 req/min free)
FINNHUB_API_KEY=

# SnapTrade — read-only broker sync (optional)
# SNAPTRADE_CLIENT_ID=
# SNAPTRADE_CONSUMER_KEY=
# SNAPTRADE_USER_ID=
# SNAPTRADE_USER_SECRET=
# SNAPTRADE_ACCOUNT_ID=

# Model overrides (optional; defaults set in app/config.py)
# WORKHORSE_MODEL=google/gemini-3.1-flash-lite
# PREMIUM_MODEL=anthropic/claude-sonnet-5

# Watchlist SQLite path (optional; defaults to ./stocks.db)
# STOCKS_DB_PATH=stocks.db

# SEC EDGAR requires a contact email (used by edgartools). Default falls back to ikusner13@gmail.com if unset. Optional.
# SEC_IDENTITY=you@example.com

# FRED API key for macro context (https://fred.stlouisfed.org/docs/api/api_key.html). Optional; macro section is hidden when unset.
# FRED_API_KEY=

# Daily portfolio job + optional Discord drift alerts. Set DAILY_JOB_HOUR_UTC below 0 to disable the loop.
# DISCORD_WEBHOOK_URL=
# DAILY_JOB_HOUR_UTC=21
# DRIFT_ALERT_ENABLED=1

# Cloudflare Tunnel token — only for production deploys via deploy/docker-compose.yml
# (see docs/deployment.md). Not read by the app itself.
# CLOUDFLARE_TUNNEL_TOKEN=
