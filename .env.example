# OpenRouter — https://openrouter.ai/keys  (required)
OPENROUTER_API_KEY=

# Finnhub — https://finnhub.io/  (optional; real-time US quotes + news, 60 req/min free)
FINNHUB_API_KEY=

# Model overrides (optional; defaults set in src/llm/provider.ts)
# WORKHORSE_MODEL=google/gemini-2.5-flash
# PREMIUM_MODEL=anthropic/claude-sonnet-4.6

# Portfolio sidecar (optional; W5). Default http://localhost:8000.
# Run it with: cd sidecar && docker compose up
# PORTFOLIO_SIDECAR_URL=http://localhost:8000
